# ===============================
# Skyward Common - .env.example
# Copy to `.env` and fill in REQUIRED fields.
# Safe to commit. Do NOT put real secrets in Git.
# ===============================

# ---- Which config to load: DEV | PROD ----
ENV=DEV

# ---- Google Cloud (BigQuery / Drive) ----
# Project ID is always required.
GCP_DATAHUB_PROJECT_ID=data-hub-468216

# GCP credentials: leave EMPTY to use Application Default Credentials (ADC).
# For ADC, run once:  gcloud auth application-default login
# To use a service account file instead, set the path relative to project root:
# GCP_DATAHUB_CREDENTIALS=secrets/your-sa.json
GCP_DATAHUB_CREDENTIALS=

# Google Drive (same pattern — empty = ADC, or set a path)
# GDRIVE_CREDENTIALS=secrets/your-sa.json
GDRIVE_CREDENTIALS=
# GDRIVE_OAUTH_TOKEN=secrets/your-oauth-token.json
GDRIVE_OAUTH_TOKEN=

# ---- DataForSEO ----
DATAFORSEO_API_LOGIN=your-login
DATAFORSEO_API_PASSWORD=your-password

# ---- OpenAI ----
OPENAI_API_KEY=your-openai-api-key

# ---- Perplexity ----
PERPLEXITY_API_KEY=your-perplexity-api-key

# ---- Gemini ----
GEMINI_API_KEY=your-gemini-api-key

# ---- Claude ----
# CLAUDE_API_CREDENTIALS=secrets/your.json

# ---- Slack Webhooks ----
SLACK_WEBHOOK_GENERAL=https://hooks.slack.com/services/T.../B.../xxx
SLACK_WEBHOOK_ALERTS=https://hooks.slack.com/services/T.../B.../xxx
